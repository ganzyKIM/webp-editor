# ── Supabase (Vercel 배포 시 필수, 로컬 개발 시 없어도 됨) ──────────────────
# Supabase 프로젝트 > Settings > API 에서 복사
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# Service Role key (secret, 절대 프론트에 노출 금지)
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# 버킷 이름 (기본값: webp-uploads)
SUPABASE_BUCKET=webp-uploads

# ── 로컬 개발 ────────────────────────────────────────────────────────────────
PORT=3939
